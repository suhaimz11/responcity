{
  "expo": {
    "name": "Responcity",
    "slug": "responcity-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "responcity",
    "splash": {
      "image": "./assets/responcity-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFCFF"
    },
    "androidStatusBar": {
      "backgroundColor": "#FAFCFF",
      "barStyle": "dark-content"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.responcity.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Responcity uses your location to alert nearby verified responders during an emergency.",
        "NSCameraUsageDescription": "Responcity uses the camera so you can capture emergency proof.",
        "NSMicrophoneUsageDescription": "Responcity uses the microphone when you record video proof."
      }
    },
    "android": {
      "package": "com.responcity.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "RECORD_AUDIO"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "replace-with-eas-project-id-when-created"
      }
    }
  }
}
