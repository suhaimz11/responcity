{
  "expo": {
    "name": "Emerge Aid",
    "slug": "emerge-aid-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "emergeaid",
    "icon": "./assets/emerge-aid-icon-fit.png",
    "splash": {
      "image": "./assets/emerge-aid-splash-transparent.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFCFF"
    },
    "androidStatusBar": {
      "backgroundColor": "#FAFCFF",
      "barStyle": "dark-content"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emergeaid.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Emerge Aid uses your location to alert nearby verified responders during an emergency.",
        "NSCameraUsageDescription": "Emerge Aid uses the camera so you can capture emergency proof.",
        "NSMicrophoneUsageDescription": "Emerge Aid uses the microphone when you record video proof."
      }
    },
    "android": {
      "package": "com.emergeaid.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "RECORD_AUDIO"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "ff0327e0-7604-4c20-85a1-14121fd7cc19"
      }
    }
  }
}
